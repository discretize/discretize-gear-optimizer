{
  "name": "discretize-gear-optimizer",
  "version": "1.0.0",
  "private": true,
  "description": "Discretize Gear Optimizer",
  "author": "marcustyphoon, gw2princeps, metagame",
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7",
  "engines": {
    "node": ">=20",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "type": "module",
  "browserslist": [
    "defaults and supports es6-module"
  ],
  "scripts": {
    "develop": "vite",
    "dev": "vite",
    "start": "vite",
    "dev-cf": "VITE_HAS_CF=true wrangler pages dev --kv SHORT_LINKS -- pnpm dev",
    "build": "vite build",
    "serve": "vite preview --host",
    "build-cf": "VITE_HAS_CF=true vite build",
    "serve-cf": "VITE_HAS_CF=true wrangler pages dev --kv SHORT_LINKS -- pnpm serve",
    "build-gh": "vite build --base /discretize-gear-optimizer/",
    "prettier": "prettier --write .",
    "prettierCheck": "prettier --check .",
    "eslint": "eslint --ignore-path .gitignore --max-warnings 0 \"**/*.{js,jsx,ts,tsx}\" --cache",
    "typeCheck": "tsc --incremental",
    "lint-staged": "lint-staged",
    "checkStaged": "concurrently -g -c auto pnpm:testData pnpm:validateDataTypes pnpm:lint-staged",
    "checkAll": "concurrently -g -c auto pnpm:testData pnpm:validateDataTypes pnpm:eslint pnpm:prettierCheck pnpm:typeCheck",
    "updateMappings": "node updateMappings.js",
    "testData": "tsx ./src/assets/testData.js",
    "validateDataTypes": "typia generate --input ./src/assets/typevalidation/ --output ./src/assets/typevalidation/output && tsx ./src/assets/typevalidation/output",
    "extractLocale": "babel --config-file ./babel-extract.config.js 'src/**/*.{js,jsx,ts,tsx}' > /dev/null",
    "extractLocaleEn": "babel --config-file ./babel-extract-en.config.js 'src/**/*.{js,jsx,ts,tsx}' > /dev/null && node cleanupLocale.js",
    "extractLocaleCMD": "babel --config-file ./babel-extract.config.js \"src/**/*.{js,jsx,ts,tsx}\" > NUL",
    "extractLocaleEnCMD": "babel --config-file ./babel-extract-en.config.js \"src/**/*.{js,jsx,ts,tsx}\" > NUL && node cleanupLocale.js",
    "cleanupLocale": "node cleanupLocale.js",
    "wasm": "wasm-pack build ./wasm_module --target web --release",
    "wasm-build-data": "tsx generateRustMappings.ts",
    "wasmCheck": "cd wasm_module && cargo check --all-targets",
    "enable-hooks": "husky",
    "disable-hooks": "git config --unset core.hooksPath"
  },
  "exports": {
    "./gw2-data": "./src/utils/gw2-data.ts",
    "./presetdata/metadata": "./src/assets/presetdata/metadata.ts"
  },
  "dependencies": {
    "@discretize/gw2-ui-new": "^3.6.1",
    "@discretize/object-compression": "^1.0.3",
    "@discretize/react-discretize-components": "^3.6.1",
    "@discretize/typeface-menomonia": "^0.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "comlink": "^4.4.2",
    "i18next": "^26.3.4",
    "js-yaml": "^4.2.0",
    "json-url": "^3.1.0",
    "material-ui-popup-state": "^5.3.7",
    "pako": "^3.0.0",
    "proxy-memoize": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-fast-compare": "^3.2.2",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1",
    "tss-react": "^4.9.21",
    "typeface-fira-mono": "^1.1.13",
    "typeface-muli": "^1.1.13",
    "typeface-raleway": "^1.1.13",
    "uint8array-extras": "^1.5.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@cloudflare/workers-types": "^4.20260620.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.4",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-i18next-extract": "^1.1.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typia": "^12.1.1",
    "vite": "^8.1.3",
    "vite-plugin-comlink": "^5.3.0",
    "vite-plugin-wasm": "^3.6.0",
    "wasm-pack": "^0.15.0",
    "wrangler": "^4.107.0",
    "yaml": "^2.9.0"
  },
  "resolutions": {
    "eslint-plugin-jsdoc": "63.0.10"
  }
}
